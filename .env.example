# --- LLM backend (hybrid) ---
# auto   = Ollama if reachable, else Claude (free locally, Claude on Railway)
# ollama = force local Ollama   |   claude = force the Claude API
LLM_BACKEND=auto

# Ollama (local LLM — free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3

# Claude (cloud fallback — needed on Railway where Ollama isn't available).
# Haiku costs ~$0.003/lead. Get a key at console.anthropic.com.
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# Gemini (FREE cloud fallback — ~1,500 req/day, no card). Used by GitHub Actions.
# Get a free key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Gmail SMTP (use a Google App Password, not your login password)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where the digest goes
RECIPIENT_EMAIL=tsiflik@bc.edu

# Tuning (optional)
COMPANIES_PER_RUN=5
MAX_CANDIDATES_TO_SCAN=40
DRY_RUN=false

# On Railway: point the dedup log at the mounted persistent volume so it
# survives between runs (containers are ephemeral). Leave unset locally.
# SENT_LOG_PATH=/data/sent_companies.json

# Optional: Google Maps Platform key — confirms address + counts locations.
# (Maps does NOT return building m².) Leave blank to keep Maps OFF (default).
# GOOGLE_MAPS_API_KEY=

# Optional: measure real building footprints from OpenStreetMap (free, no key).
# Best for malls/big-box/factories; slower (rate-limited). Default OFF.
# USE_OVERPASS=true
